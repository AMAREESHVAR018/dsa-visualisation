🔢 Q1. Basic Prim’s
✅ Java
import java.util.*;

void prim(List<List<int[]>> graph) {
    int n = graph.size();
    boolean[] visited = new boolean[n];

    PriorityQueue<int[]> pq = new PriorityQueue<>((a,b)->a[1]-b[1]);

    pq.add(new int[]{0, 0}); // node, weight
    int cost = 0;

    while (!pq.isEmpty()) {
        int[] cur = pq.poll();
        int node = cur[0], weight = cur[1];

        if (visited[node]) continue;

        visited[node] = true;
        cost += weight;

        for (int[] nei : graph.get(node)) {
            if (!visited[nei[0]]) {
                pq.add(new int[]{nei[0], nei[1]});
            }
        }
    }

    System.out.println("MST Cost: " + cost);
}
🐍 Python
import heapq

def prim(graph):
    n = len(graph)
    visited = [False]*n

    pq = [(0, 0)]  # (weight, node)
    cost = 0

    while pq:
        weight, node = heapq.heappop(pq)

        if visited[node]:
            continue

        visited[node] = True
        cost += weight

        for nei, w in graph[node]:
            if not visited[nei]:
                heapq.heappush(pq, (w, nei))

    print("MST Cost:", cost)
