📈 10. Maximum Subarray Sum
➡️ Maximum Subarray

❌ Approach 1: Brute Force
Check all subarrays

Time: O(n²)

class Solution {
    public int maxSubArray(int[] nums) {
        int maxSum = Integer.MIN_VALUE;

        for (int i = 0; i < nums.length; i++) {
            int sum = 0;
            for (int j = i; j < nums.length; j++) {
                sum += nums[j];
                maxSum = Math.max(maxSum, sum);
            }
        }
        return maxSum;
    }
}
⚡ Approach 2: Kadane’s Algorithm (🔥 MUST KNOW)
class Solution {
    public int maxSubArray(int[] nums) {
        int maxSum = nums[0];
        int curr = nums[0];

        for (int i = 1; i < nums.length; i++) {
            curr = Math.max(nums[i], curr + nums[i]);
            maxSum = Math.max(maxSum, curr);
        }

        return maxSum;
    }
}
🧠 Approach 3: DP
class Solution {
    public int maxSubArray(int[] nums) {
        int n = nums.length;
        int[] dp = new int[n];

        dp[0] = nums[0];
        int max = dp[0];

        for (int i = 1; i < n; i++) {
            dp[i] = Math.max(nums[i], dp[i-1] + nums[i]);
            max = Math.max(max, dp[i]);
        }

        return max;
    }
}
🔥 Approach 4: Divide & Conquer
class Solution {
    public int maxSubArray(int[] nums) {
        return helper(nums, 0, nums.length - 1);
    }

    private int helper(int[] nums, int l, int r) {
        if (l == r) return nums[l];

        int mid = (l + r) / 2;

        int left = helper(nums, l, mid);
        int right = helper(nums, mid + 1, r);

        int leftSum = Integer.MIN_VALUE, sum = 0;
        for (int i = mid; i >= l; i--) {
            sum += nums[i];
            leftSum = Math.max(leftSum, sum);
        }

        int rightSum = Integer.MIN_VALUE; sum = 0;
        for (int i = mid + 1; i <= r; i++) {
            sum += nums[i];
            rightSum = Math.max(rightSum, sum);
        }

        return Math.max(Math.max(left, right), leftSum + rightSum);
    }
}
🚉 11. Minimum Platforms Required
➡️ Meeting Rooms II

⚡ Approach 1: Sorting + Two Pointers (BEST)
import java.util.*;

class Solution {
    public int findPlatform(int[] arr, int[] dep) {
        Arrays.sort(arr);
        Arrays.sort(dep);

        int i = 0, j = 0;
        int platforms = 0, maxPlatforms = 0;

        while (i < arr.length && j < dep.length) {
            if (arr[i] <= dep[j]) {
                platforms++;
                i++;
            } else {
                platforms--;
                j++;
            }
            maxPlatforms = Math.max(maxPlatforms, platforms);
        }

        return maxPlatforms;
    }
}
🧠 Approach 2: Using Priority Queue (Min Heap)
import java.util.*;

class Solution {
    public int findPlatform(int[] arr, int[] dep) {
        int n = arr.length;
        int[][] trains = new int[n][2];

        for (int i = 0; i < n; i++) {
            trains[i][0] = arr[i];
            trains[i][1] = dep[i];
        }

        Arrays.sort(trains, (a, b) -> a[0] - b[0]);

        PriorityQueue<Integer> pq = new PriorityQueue<>();

        pq.add(trains[0][1]);

        for (int i = 1; i < n; i++) {
            if (pq.peek() < trains[i][0]) {
                pq.poll();
            }
            pq.add(trains[i][1]);
        }

        return pq.size();
    }
}
