🔁 Approach 3: Using FSM (Advanced)
Finite State Machine (for top companies)

class Solution {
    public int myAtoi(String s) {
        int state = 0, sign = 1;
        long num = 0;

        for (char c : s.toCharArray()) {
            if (state == 0) {
                if (c == ' ') continue;
                else if (c == '+') state = 1;
                else if (c == '-') { state = 1; sign = -1; }
                else if (Character.isDigit(c)) {
                    state = 2;
                    num = c - '0';
                } else return 0;
            }
            else if (state == 1 || state == 2) {
                if (Character.isDigit(c)) {
                    state = 2;
                    num = num * 10 + (c - '0');

                    if (sign * num > Integer.MAX_VALUE) return Integer.MAX_VALUE;
                    if (sign * num < Integer.MIN_VALUE) return Integer.MIN_VALUE;
                } else break;
            }
        }

        return (int)(sign * num);
    }
}
