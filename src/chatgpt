class Solution {
    public int replaceZero(int num) {
        if (num == 0) return 5;

        int res = 0, place = 1;

        while (num > 0) {
            int digit = num % 10;

            if (digit == 0) digit = 5;

            res += digit * place;
            place *= 10;
            num /= 10;
        }

        return res;
    }
}
