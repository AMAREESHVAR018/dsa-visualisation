    PriorityQueue<int[]> pq = new PriorityQueue<>((a,b)->a[1]-b[1]);
    dist[src] = 0;
    pq.add(new int[]{src, 0});

    while (!pq.isEmpty()) {
        int[] cur = pq.poll();
        int u = cur[0];

        for (int[] nei : graph.get(u)) {
            int v = nei[0], w = nei[1];

            if (dist[u] + w < dist[v]) {
                dist[v] = dist[u] + w;
                pq.add(new int[]{v, dist[v]});
            }
        }
    }
}
