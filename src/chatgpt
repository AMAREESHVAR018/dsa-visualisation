int mergeInv(int[] arr, int l, int m, int r) {
    int[] temp = new int[r-l+1];
    int i=l, j=m+1, k=0, inv=0;

    while (i<=m && j<=r) {
        if (arr[i] <= arr[j]) temp[k++] = arr[i++];
        else {
            temp[k++] = arr[j++];
            inv += (m - i + 1);
        }
    }

    while (i<=m) temp[k++] = arr[i++];
    while (j<=r) temp[k++] = arr[j++];

    for (i=l;i<=r;i++) arr[i]=temp[i-l];

    return inv;
}
