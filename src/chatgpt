class Solution {
    public void printCircular(Node head) {
        if (head == null) return;

        Node temp = head;
        boolean first = true;

        while (temp != head || first) {
            first = false;
            System.out.print(temp.data + " ");
            temp = temp.next;
        }
    }
}
