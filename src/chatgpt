class Solution {
    public int findCelebrity(int[][] mat) {
        int n = mat.length;

        for (int i = 0; i < n; i++) {
            boolean isCelebrity = true;

            for (int j = 0; j < n; j++) {
                if (i != j && (mat[i][j] == 1 || mat[j][i] == 0)) {
                    isCelebrity = false;
                    break;
                }
            }

            if (isCelebrity) return i;
        }
        return -1;
    }
}
⚡ Approach 2: Optimal (Two-Pointer Elimination)
🔥 Most important for interviews

Eliminate non-celebrities in one pass

Verify candidate

class Solution {
    public int findCelebrity(int[][] mat) {
        int n = mat.length;

        int candidate = 0;

        // Step 1: Find candidate
        for (int i = 1; i < n; i++) {
            if (mat[candidate][i] == 1) {
                candidate = i;
            }
        }

        // Step 2: Verify candidate
        for (int i = 0; i < n; i++) {
            if (i != candidate &&
               (mat[candidate][i] == 1 || mat[i][candidate] == 0)) {
                return -1;
            }
        }

        return candidate;
    }
}
🔥 Approach 3: Stack-Based
Eliminate using stack

import java.util.*;

class Solution {
    public int findCelebrity(int[][] mat) {
        int n = mat.length;
        Stack<Integer> stack = new Stack<>();

        for (int i = 0; i < n; i++) stack.push(i);

        while (stack.size() > 1) {
            int a = stack.pop();
            int b = stack.pop();

            if (mat[a][b] == 1) stack.push(b);
            else stack.push(a);
        }

        int candidate = stack.pop();

        for (int i = 0; i < n; i++) {
            if (i != candidate &&
               (mat[candidate][i] == 1 || mat[i][candidate] == 0)) {
                return -1;
            }
        }

        return candidate;
    }
}
📐 5. Rectangle Overlap
➡️ Rectangle Overlap

🧠 Key Idea
Rectangles do NOT overlap if:

One is left of other

One is above other

⚡ Approach 1: Optimal Geometry Check
Time: O(1)

class Solution {
    public boolean isOverlap(int[] l1, int[] r1, int[] l2, int[] r2) {

        // If one is left of other
        if (l1[0] >= r2[0] || l2[0] >= r1[0]) return false;

        // If one is above other
        if (r1[1] >= l2[1] || r2[1] >= l1[1]) return false;

        return true;
    }
}
❌ Approach 2: Area-Based (Conceptual)
Compute intersection area

class Solution {
    public boolean isOverlap(int[] l1, int[] r1, int[] l2, int[] r2) {

        int xOverlap = Math.min(r1[0], r2[0]) - Math.max(l1[0], l2[0]);
        int yOverlap = Math.min(l1[1], l2[1]) - Math.max(r1[1], r2[1]);

        return xOverlap > 0 && yOverlap > 0;
    }
}
